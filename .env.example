# ===========================================
# CMS API Configuration (UniVerse Headless CMS)
# ===========================================

# Base URL server CMS
VITE_CMS_BASE_URL=https://uni-verse-headless-cms.onrender.com

# API Key untuk autentikasi ke CMS
VITE_CMS_API_KEY=uni_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Gemini AI (opsional)
# ===========================================
GEMINI_API_KEY=MY_GEMINI_API_KEY

# APP_URL: URL aplikasi ini dihosting
APP_URL=MY_APP_URL
